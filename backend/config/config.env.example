# =============================================================
# MediHelp — Backend Environment Configuration
# =============================================================
# Copy this file to: backend/config/config.env
# Then fill in YOUR OWN values below.
#
#   cp backend/config/config.env.example backend/config/config.env
#
# NEVER commit config.env — it contains secrets unique to you.
# =============================================================

# ---- Server ----
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5001

# ---- MongoDB ----
# Local:  mongodb://localhost:27017/medihelp
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/medihelp
MONGO_URI=mongodb://localhost:27017/medihelp

# ---- JWT Authentication ----
# IMPORTANT: Generate a unique, random secret for YOUR installation.
# Run this in your terminal to generate one:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=PASTE_YOUR_GENERATED_SECRET_HERE
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# ---- Email Notifications (optional) ----
# Used for emergency SOS alerts. Get an App Password from Google:
# https://myaccount.google.com/apppasswords
EMAIL_USER=
EMAIL_PASS=

# ---- Twilio SMS (optional) ----
# Sign up at https://www.twilio.com/ for a free trial
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
